# Vorlage — echte Werte gehören in .env.local (ist git-ignoriert).

# Auth-Gate (HTTP Basic Auth, middleware.ts). BEIDE auf Vercel setzen, sonst
# ist das Dashboard öffentlich erreichbar! Lokal optional (leer = kein Gate).
DASHBOARD_AUTH_USER=
DASHBOARD_AUTH_PASSWORD=

# Supabase (server-seitiger Anon-Key, RLS bestimmt die Sichtbarkeit.
# Lesezugriff auf alle Dashboard-Tabellen; Schreibzugriff NUR auf
# dashboard.todo_items — für den To-Do-Route-Handler /api/todos.)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# GitHub-Widget: Repo im Format owner/repo; Token nur für private Repos
# bzw. höheres Rate-Limit nötig (fine-grained, read-only auf Contents/Issues)
GITHUB_REPO=
GITHUB_TOKEN=

# Stripe (DDD-Detailseite: MRR + Monatsumsatz, read-only über die REST-API).
# Secret Key aus dem Stripe-Dashboard; OHNE NEXT_PUBLIC — nur server-seitig.
STRIPE_SECRET_KEY=

# NUR für die scripts/sync-*.js (Hermes-Cron, lokal).
# NIEMALS auf Vercel setzen, niemals im Frontend verwenden!
SUPABASE_SERVICE_ROLE_KEY=
