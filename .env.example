# Vorlage — echte Werte gehören in .env.local (ist git-ignoriert).

# Supabase (Frontend: nur Lesezugriff über den Anon-Key, RLS bestimmt die Sichtbarkeit)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# GitHub-Widget: Repo im Format owner/repo; Token nur für private Repos
# bzw. höheres Rate-Limit nötig (fine-grained, read-only auf Contents/Issues)
GITHUB_REPO=
GITHUB_TOKEN=

# Google Calendar + Tasks (Kalender-Widget, read-only).
# OAuth2-Client in der GCP-Console anlegen, Refresh-Token z. B. über den
# OAuth 2.0 Playground erzeugen — Scopes: calendar.readonly, tasks.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# NUR für die scripts/sync-*.js (Hermes-Cron, lokal).
# NIEMALS auf Vercel setzen, niemals im Frontend verwenden!
SUPABASE_SERVICE_ROLE_KEY=
